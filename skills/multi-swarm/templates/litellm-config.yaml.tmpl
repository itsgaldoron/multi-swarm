general_settings:
  master_key: {{masterKey}}
  enable_jwt_auth: false

router_settings:
  routing_strategy: {{routingStrategy}}
  cooldown_time: {{cooldownSeconds}}
  num_retries: 3
  allowed_fails: 2
  retry_after: 5
  enable_pre_call_checks: true
  timeout: 600
  stream_timeout: 600

litellm_settings:
  drop_params: true
  set_verbose: false
  cache: false
  request_timeout: 600

model_list:
{{#each tokens}}
